{
  "mods": [
    {
      "id": "bepinex-il2cpp-x64",
      "engine": "Unity",
      "unityBackend": "Il2Cpp",
      "author": "BepInEx",
      "sourceCode": "https://github.com/BepInEx/BepInEx",
      "install": {
        "extract": [
          {
            "source": "BepInEx",
            "destination": "{{InstalledModsPath}}/bepinex/BepInEx"
          },
          {
            "source": "dotnet",
            "destination": "{{InstalledModsPath}}/bepinex/dotnet"
          },
          {
            "source": "winhttp.dll",
            "destination": "{{GameExecutableFolderPath}}/winhttp.dll"
          }
        ],
        "write": [
          {
            "content": "[General]\nenabled = true\ntarget_assembly = {{InstalledModsPath}}/bepinex/BepInEx/core/BepInEx.Unity.IL2CPP.dll\nredirect_output_log = false\nboot_config_override =\nignore_disable_switch = true\n\n[Il2Cpp]\ncoreclr_path = {{InstalledModsPath}}/bepinex/dotnet/coreclr.dll\ncorlib_dir = {{InstalledModsPath}}/bepinex/dotnet\n",
            "destination": "{{GameExecutableFolderPath}}/doorstop_config.ini"
          },
          {
            "content": "[Logging.Console]\nEnabled = true",
            "destination": "{{InstalledModsPath}}/bepinex/BepInEx/config/BepInEx.cfg"
          }
        ],
        "wineDllOverrides": [
          "winhttp"
        ],
        "mainInstalledFolderPath": "{{InstalledModsPath}}/bepinex/BepInEx"
      },
      "config": {
        "destinationPath": "{{InstalledModsPath}}/bepinex/BepInEx/config/BepInEx.cfg",
        "destinationType": "File"
      },
      "architecture": "X64",
      "title": "BepInEx Il2Cpp X64",
      "description": "BepInEx bleeding-edge Il2Cpp build for X64 games.",
      "latestVersion": {
        "id": "6.0.0-be.755",
        "url": "https://builds.bepinex.dev/projects/bepinex_be/755/BepInEx-Unity.IL2CPP-win-x64-6.0.0-be.755%2B3fab71a.zip"
      },
      "hash": "bc34e2477bdfcb0f638a35d98645e651d01a998c051641f182a8bd3292934505"
    },
